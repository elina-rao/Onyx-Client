# Onyx marketing site — copy to .env and fill as assets go live.
# Restart `npm run dev` after changing env vars.

# Server / community
VITE_SERVER_IP=eu.onyxrbw.com
VITE_DISCORD_INVITE=https://discord.gg/onyxrbw

# Launcher downloads (direct URLs to release assets). Empty = "building…" on /client.
# Public release: https://github.com/elina-rao/onyx-releases/releases
VITE_DOWNLOAD_MAC=https://github.com/elina-rao/onyx-releases/releases/download/v1.0.3/OnyxLauncher-1.0.3-arm64.dmg
VITE_DOWNLOAD_WIN=https://github.com/elina-rao/onyx-releases/releases/download/v1.0.3/OnyxLauncher-Setup-1.0.3.exe

# Optional Discord count overrides if the invite API is unavailable
VITE_DISCORD_ONLINE=
VITE_DISCORD_MEMBERS=

# Trailer (YouTube or direct video). Empty hides the Trailer section.
VITE_TRAILER_URL=

# Footer socials (empty = icon hidden)
VITE_YOUTUBE_URL=
VITE_TIKTOK_URL=
VITE_INSTAGRAM_URL=
